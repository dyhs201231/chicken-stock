generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EducationSummaryLabel {
  BEGINNER // 초급
  INTERMEDIATE // 중급
  ADVANCED // 고급
}

enum Quiz_type {
  MULTIPLE_CHOICE // 객관식
  TRUE_FALSE // O/X
  SHORT_ANSWER // 주관식
}

enum InvestmentType {
  AGGRESSIVE // 공격투자형
  ACTIVE // 적극투자형
  BALANCED // 위험중립형
  CONSERVATIVE // 안정추구형
  STABLE // 안정형
}

model User {
  id                 BigInt                  @id @default(autoincrement())
  type               UserType                @default(NORMAL)
  name               String                  @default("") @db.VarChar(255)
  email              String?                 @unique @db.VarChar(255)
  investmentType     InvestmentType?         @map("investment_type")
  profileImageUrl    String?                 @map("profile_image_url") @db.VarChar(2048)
  currentLevel       Int?                    @map("current_level")
  currentStep        Int?                    @map("current_step")
  totalSteps         Int?                    @map("total_steps")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  refreshTokens      RefreshToken[]
  articleCompletions UserArticleCompletion[]

  @@index([email])
  @@map("User")
}

model RefreshToken {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("RefreshToken")
}

enum UserType {
  NORMAL
  AGENT

  @@map("User_type")
}

model Article {
  id                 Int                     @id @default(autoincrement())
  educationSummaryId Int                     @map("education_summary_id")
  educationSummary   EducationSummary        @relation(fields: [educationSummaryId], references: [id])
  quizzes            Quiz[]
  title              String
  content            String
  imageUrl           String                  @map("image_url")
  sortOrder          Int                     @default(0) @map("sort_order")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  completions        UserArticleCompletion[]

  @@index([educationSummaryId])
}

model Quiz {
  id               Int                  @id @default(autoincrement())
  educationLevelId Int                  @map("education_level_id")
  educationLevel   EducationSummary     @relation(fields: [educationLevelId], references: [stage])
  articleId        Int                  @map("article_id")
  article          Article              @relation(fields: [articleId], references: [id])
  quizType         Quiz_type            @map("quiz_type")
  question         String               @db.VarChar(255)
  description      String
  answer           String
  explanation      String
  optionText       String[]             @map("option_text") @db.VarChar(255)
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  submissions      UserQuizSubmission[]

  @@index([educationLevelId])
  @@index([articleId])
}

model UserQuizSubmission {
  userId         BigInt    @map("user_id")
  quizId         Int       @map("quiz_id")
  quiz           Quiz      @relation(fields: [quizId], references: [id])
  selectedAnswer String    @map("selected_answer")
  isSkip         Boolean   @map("is_skip")
  isCorrect      Boolean   @map("is_correct")
  answeredAt     DateTime? @map("answered_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@id([userId, quizId])
  @@map("User_quiz_submission")
}

model EducationSummary {
  id        Int                          @id @default(autoincrement())
  stage     Int                          @unique
  label     EducationSummaryLabel
  title     String                       @default("")
  imageUrl  String                       @map("image_url")
  summary   String[]
  createdAt DateTime                     @default(now()) @map("created_at")
  updatedAt DateTime                     @updatedAt @map("updated_at")
  articles  Article[]
  quizzes   Quiz[]
  progress  UserEducationLevelProgress[]

  @@map("Education_summary")
}

model UserEducationLevelProgress {
  userId           BigInt           @map("user_id")
  educationLevelId Int              @map("education_level_id")
  educationLevel   EducationSummary @relation(fields: [educationLevelId], references: [stage])
  isLocked         Boolean          @map("is_locked")
  progressRate     Int              @map("progress_rate")
  currentStep      Int              @map("current_step")
  totalSteps       Int              @map("total_steps")
  startedAt        DateTime         @map("started_at")
  completedAt      DateTime         @map("completed_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@id([userId, educationLevelId])
  @@map("User_education_level_progress")
}

model UserArticleCompletion {
  userId       BigInt    @map("user_id")
  articleId    Int       @map("article_id")
  user         User      @relation(fields: [userId], references: [id])
  article      Article   @relation(fields: [articleId], references: [id])
  progressRate Int       @default(0) @map("progress_rate")
  isCompleted  Boolean   @default(false) @map("is_completed")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@id([userId, articleId])
  @@map("User_article_completion")
}
